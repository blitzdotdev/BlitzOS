{
  "manifest_version": 3,
  "name": "BlitzOS Connector",
  "version": "0.1.0",
  "description": "Connects a Chrome tab to BlitzOS so your agent can read and act on the tabs you explicitly connect. Drives only connected tabs.",
  "minimum_chrome_version": "116",
  "background": { "service_worker": "sw.js", "type": "module" },
  "permissions": ["scripting", "tabs", "alarms", "storage"],
  "host_permissions": ["<all_urls>"],
  "storage": { "managed_schema": "managed_schema.json" },
  "key": ""
}
