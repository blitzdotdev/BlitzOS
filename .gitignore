node_modules/
out/
dist/
*.log
.DS_Store

# real OAuth client ids / secrets (keep only the .example version in git)
integrations.config.json

# preview backend: stored OAuth tokens (real account creds) — never commit
preview/.tokens.json

# saved cloudflared tunnel token — never commit
preview/.cf-tunnel-token

# persistent server-browser profile (the user's logged-in cookies/sessions) — never commit
.blitz-chrome-profile/

# agent-authored widgets saved at runtime (the tracked widget library is widgets/*.html)
widgets/authored/

# parked vision dump (ignore claude mono)
claude-mono*.md
